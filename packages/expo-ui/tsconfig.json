{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "../../.cache/tsbuild/expo-ui.tsbuildinfo"
  },
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../react"
    }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
