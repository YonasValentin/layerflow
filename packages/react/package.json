{
  "name": "@layerflow/react",
  "version": "0.1.0",
  "description": "React bindings and typed presentation registry for Layerflow.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "use-sync-external-store": "^1.6.0"
  },
  "peerDependencies": {
    "@layerflow/core": "^0.1.0",
    "react": ">=18.3.0"
  },
  "devDependencies": {
    "@layerflow/core": "0.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YonasValentin/layerflow.git",
    "directory": "packages/react"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean --tsconfig tsconfig.build.json --external react --external @layerflow/core --external use-sync-external-store",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  }
}
