{
  "name": "@yonas-valentin-dev/layerflow-testing",
  "version": "0.1.0",
  "description": "Deterministic test helpers for Layerflow.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "peerDependencies": {
    "@yonas-valentin-dev/layerflow-core": "^0.1.0"
  },
  "devDependencies": {
    "@yonas-valentin-dev/layerflow-core": "0.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YonasValentin/layerflow.git",
    "directory": "packages/testing"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean --tsconfig tsconfig.build.json --external @yonas-valentin-dev/layerflow-core",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "homepage": "https://github.com/YonasValentin/layerflow#readme",
  "bugs": {
    "url": "https://github.com/YonasValentin/layerflow/issues"
  },
  "author": "Yonas Valentin",
  "keywords": [
    "testing",
    "test-helpers",
    "overlay",
    "presentation",
    "scheduler",
    "vitest"
  ]
}
